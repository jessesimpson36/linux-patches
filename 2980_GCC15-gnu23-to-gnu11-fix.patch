--- a/arch/x86/boot/compressed/Makefile	2025-05-03 16:16:16.932485667 -0400
+++ b/arch/x86/boot/compressed/Makefile	2025-05-03 16:16:57.757770067 -0400
@@ -33,7 +33,7 @@ targets := vmlinux vmlinux.bin vmlinux.b
