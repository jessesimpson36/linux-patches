 {
 	shiftfs_file_info_cache = kmem_cache_create(
 		"shiftfs_file_info_cache", sizeof(struct shiftfs_file_info), 0,
-		SLAB_HWCACHE_ALIGN | SLAB_ACCOUNT | SLAB_MEM_SPREAD, NULL);
